APP_ORIGIN=https://your-staging-url.example.com
CORS_ALLOWED_ORIGINS=https://your-staging-url.example.com
PULSEPEAK_DB_PATH=/tmp/pulsepeak-db.json
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_YEARLY_PRICE_ID=price_yearly_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_CENTS=1499
STRIPE_PREMIUM_YEARLY_PRICE_CENTS=11999
STRIPE_PREMIUM_CURRENCY=usd
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Persistence: point at a PERSISTENT disk in production (Render disk mount or a
# managed DB). The /tmp default above is EPHEMERAL and wipes user data on deploy.
# PULSEPEAK_DB_PATH=/data/pulsepeak-db.json

# Optional, dormant until set. Privacy-friendly analytics (cookieless).
# When set, also add the analytics host to server CSP script-src/connect-src.
# VITE_PLAUSIBLE_DOMAIN=pulsepeak.app
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Optional crash reporting integration point (see src/components/ErrorBoundary.jsx
# window.__pulsepeakReportError hook). Wire Sentry here when a DSN is available.
# VITE_SENTRY_DSN=
